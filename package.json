{
  "name": "react-native-kustom-inapp-sdk",
  "title": "Kustom Mobile SDK React Native",
  "version": "1.0.3",
  "description": "This library wraps Kustom Mobile SDK and exposes its functionality as React Native components.",
  "source": "./src/index.tsx",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "!ios/build",
    "!ios/Podfile",
    "!ios/Pods",
    "!ios/RNKustomMobileSDK.xcworkspace",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "prepack": "bob build",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,tsx}\" --fix",
    "prettier": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "prettier:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "clean": "del-cli android/build ios/build TestApp/android/build TestApp/android/app/build TestApp/ios/build",
    "pods": "pod-install --quiet",
    "test:android": "cd TestApp/android && ./gradlew :react-native-kustom-inapp-sdk:testDebugUnitTest && cd ../..",
    "test:ios": "cd ios && xcodebuild test -workspace RNKustomMobileSDK.xcworkspace -scheme RNKustomMobileSDK -sdk iphonesimulator -destination 'platform=iOS Simulator,name=iPhone 16'",
    "build:android": "cd TestApp/android && ./gradlew assembleDebug --no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a",
    "build:ios": "cd TestApp/ios && xcodebuild -workspace TestApp.xcworkspace -scheme TestApp -configuration Debug -sdk iphonesimulator CC=clang CPLUSPLUS=clang++ LD=clang LDPLUSPLUS=clang++ GCC_OPTIMIZATION_LEVEL=0 GCC_PRECOMPILE_PREFIX_HEADER=YES ASSETCATALOG_COMPILER_OPTIMIZATION=time DEBUG_INFORMATION_FORMAT=dwarf COMPILER_INDEX_STORE_ENABLE=NO",
    "android": "yarn --cwd TestApp android",
    "ios": "yarn --cwd TestApp ios",
    "start": "yarn --cwd TestApp start",
    "TestApp": "yarn --cwd TestApp"
  },
  "keywords": [
    "react-native",
    "kustom",
    "sdk"
  ],
  "repository": "https://github.com/Kustom-Checkout/react-native-kustom-inapp-sdk",
  "author": "Kustom App <kustom-app@kustom.co>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Kustom-Checkout/react-native-kustom-inapp-sdk#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "licenseFilename": "LICENSE",
  "readmeFilename": "README.md",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.83.4",
    "@react-native/eslint-config": "0.83.4",
    "@types/jest": "^29.5.4",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jest": "^27.2.3",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.2.1",
    "pod-install": "^0.1.0",
    "prettier": "^3.0.3",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-builder-bob": "^0.41.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.4.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNKustomMobileSDK",
    "type": "all",
    "jsSrcsDir": "src/specs",
    "android": {
      "javaPackageName": "com.kustom.mobile.sdk.reactnative"
    },
    "ios": {
      "componentProvider": {
        "RNKustomCheckoutView": "KustomCheckoutViewWrapper"
      }
    }
  }
}
